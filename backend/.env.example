# Copy to .env and fill in. Never commit the real .env.

# --- Database ---------------------------------------------------------------

# MongoDB Atlas connection string (Database > Connect > Drivers)
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/

# Database name
DB_NAME=supermarket_assistant

# --- App --------------------------------------------------------------------

# Comma-free JSON list of allowed frontend origins
FRONTEND_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Set true for verbose errors in development
DEBUG=false

# Supermarket name shown in the dashboard
SUPERMARKET_NAME=Foodie

# --- Vapi (outbound calling, Phase 5) --------------------------------------

# API key from the Vapi dashboard. Leave BLANK to run in dry-run mode:
# the compliance gate still runs and a call record is still written, but no
# real telephony happens - useful for demoing the flow without a Vapi account.
VAPI_API_KEY=

# Vapi base URL - only change for a self-hosted Vapi.
VAPI_BASE_URL=https://api.vapi.ai

# The Vapi phone number to dial FROM (the phoneNumberId in Vapi's API).
# Required for a live call; ignored in dry-run mode.
VAPI_PHONE_NUMBER_ID=

# The saved Vapi assistant to use for calls. Build this assistant ONCE in the
# Vapi dashboard from VAPI_AGENT_DESIGN.md - system prompt, voice, the four
# function tools, and a server URL pointing at <this backend>/calls/webhook.
# Required for a live call.
VAPI_ASSISTANT_ID=

# Optional: public URL where Vapi should send this backend's call webhooks.
# Use your tunnel URL plus /calls/webhook, e.g.
# https://abc123.ngrok-free.app/calls/webhook
# If omitted, the saved assistant's Server URL in Vapi is used.
VAPI_WEBHOOK_URL=

# --- Compliance (Australia, Phase 5) ---------------------------------------

# Timezone the calling-hours gate evaluates against. v1 uses a single fixed
# timezone (per-customer timezone is a noted follow-up).
CALLING_TIMEZONE=Australia/Sydney

# Permitted calling window (24h clock, local to CALLING_TIMEZONE).
# Telemarketing Industry Standard 2017: weekdays 9am-8pm, Saturday 9am-5pm.
CALLING_HOUR_START=9
CALLING_HOUR_END_WEEKDAY=20
CALLING_HOUR_END_SATURDAY=17
CALLING_ALLOW_SUNDAY=false

# Set true to bypass the calling-hours gate (demos/tests outside the window).
# The do_not_call check is NEVER bypassed, regardless of this setting.
CALLING_HOURS_OVERRIDE=false
